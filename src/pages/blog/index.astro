---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import heroBgRaw from '../../assets/backgrounds/hero-background.jpg';

const base = import.meta.env.BASE_URL;
const heroBg = await getImage({ src: heroBgRaw, width: 3000, height: 600, format: 'webp', quality: 85, fit: 'cover' });

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const CATEGORY_LABELS: Record<string, string> = {
  '2024-ai-safety':     '2024 AI Safety',
  '2025-ai-safety':     '2025 AI Safety',
  'technical-ai-safety': 'Technical AI Safety',
  'general':             'General',
};

const postsData = posts.map(p => {
  const categorySlug = p.id.split('/')[0];
  return {
    slug:     p.slug,
    title:    p.data.title,
    summary:  p.data.summary ?? '',
    tags:     p.data.tags,
    date:     p.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
    dateIso:  p.data.date.toISOString(),
    category: categorySlug,
    categoryLabel: CATEGORY_LABELS[categorySlug] ?? categorySlug,
  };
});

const allCategories = [...new Set(postsData.map(p => p.category))];
---

<BaseLayout title="Blog" description="Articles and course notes from the NTUAIS community on AI safety, alignment, and interpretability.">

  <section class="page-hero">
    <div class="page-hero-bg" style={`background-image: url('${heroBg.src}')`} aria-hidden="true"></div>
    <div class="container">
      <span class="section-badge">Blog</span>
      <h1>Posts</h1>
      <p>Research notes, course summaries, and perspectives from the NTUAIS community.</p>
    </div>
  </section>

  <section class="posts-section">
    <div class="container">

      <!-- Search + Filter Controls -->
      <div class="controls">
        <div class="search-wrap">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="16" height="16">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
          </svg>
          <input id="search-input" type="search" placeholder="Search posts…" autocomplete="off" />
        </div>

        <div class="filter-row">
          <div class="filter-group">
            <span class="filter-label">Category</span>
            <div class="chip-list" id="category-chips">
              <button class="chip active" data-category="">All</button>
              {allCategories.map(cat => (
                <button class="chip" data-category={cat}>
                  {CATEGORY_LABELS[cat] ?? cat}
                </button>
              ))}
            </div>
          </div>

        </div>
      </div>

      <!-- Result count -->
      <p class="result-count" id="result-count"></p>

      <!-- Posts list -->
      <div class="posts-list" id="posts-list">
        {postsData.map(post => (
          <a
            href={`${base}blog/${post.slug}/`}
            class="post-row card-linear"
            data-slug={post.slug}
            data-category={post.category}
            data-tags={post.tags.join(',')}
          >
            <div class="post-meta">
              <time datetime={post.dateIso}>{post.date}</time>
              <span class="chip chip--category">{post.categoryLabel}</span>
              {post.tags.slice(0, 2).map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <h2>{post.title}</h2>
            {post.summary && <p class="post-summary">{post.summary}</p>}
            <span class="post-read-more">Read more →</span>
          </a>
        ))}
      </div>

      <p class="empty-state" id="empty-state" style="display:none">No posts match your search.</p>

    </div>
  </section>

</BaseLayout>

<!-- Pass server data to client script -->
<div id="posts-data" data-posts={JSON.stringify(postsData)} style="display:none"></div>
<div id="base-url" data-base={base} style="display:none"></div>

<script>
  import Fuse from 'fuse.js';

  interface PostData {
    slug: string;
    title: string;
    summary: string;
    tags: string[];
    date: string;
    dateIso: string;
    category: string;
    categoryLabel: string;
  }

  const postsData: PostData[] = JSON.parse(
    (document.getElementById('posts-data') as HTMLElement).dataset.posts!
  );

  const fuse = new Fuse(postsData, {
    keys: [
      { name: 'title',   weight: 0.6 },
      { name: 'summary', weight: 0.3 },
      { name: 'tags',    weight: 0.1 },
    ],
    threshold: 0.35,
    includeScore: true,
  });

  let activeCategory = '';
  let searchQuery = '';

  function getVisible(): PostData[] {
    let results = searchQuery
      ? fuse.search(searchQuery).map(r => r.item)
      : postsData;

    if (activeCategory)
      results = results.filter(p => p.category === activeCategory);

    return results;
  }

  function render() {
    const visible = getVisible();
    const visibleSlugs = new Set(visible.map(p => p.slug));

    document.querySelectorAll<HTMLElement>('.post-row').forEach(el => {
      el.style.display = visibleSlugs.has(el.dataset.slug!) ? '' : 'none';
    });

    const count = document.getElementById('result-count')!;
    const empty = document.getElementById('empty-state')!;
    if (visible.length === 0) {
      count.textContent = '';
      empty.style.display = '';
    } else {
      count.textContent = `${visible.length} post${visible.length === 1 ? '' : 's'}`;
      empty.style.display = 'none';
    }
  }

  // Search input
  document.getElementById('search-input')?.addEventListener('input', e => {
    searchQuery = (e.target as HTMLInputElement).value.trim();
    render();
  });

  // Category chips
  document.getElementById('category-chips')?.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('button[data-category]');
    if (!btn) return;
    activeCategory = btn.dataset.category!;
    document.querySelectorAll('#category-chips .chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    render();
  });

  render();
</script>

<style>
  .page-hero {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--linear-border-subtle);
  }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #F7FAF9;
    margin: 0.75rem 0 0.5rem;
  }

  .page-hero p {
    color: rgba(247, 250, 249, 0.8);
    font-size: 1.05rem;
    max-width: 560px;
  }

  .page-hero .section-badge {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.25);
    color: rgba(247, 250, 249, 0.9);
  }

  .posts-section {
    padding: 3rem 0 5rem;
  }

  /* ── Controls ── */
  .controls {
    max-width: 760px;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .search-wrap {
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--linear-muted);
    pointer-events: none;
  }

  #search-input {
    width: 100%;
    padding: 0.65rem 1rem 0.65rem 2.5rem;
    font-size: 0.9rem;
    border: 1px solid var(--linear-border-subtle);
    border-radius: var(--border-radius-md);
    background: var(--linear-overlay-soft);
    color: var(--linear-text);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  #search-input:focus {
    border-color: var(--linear-accent-green);
    box-shadow: 0 0 0 3px rgba(45, 122, 103, 0.12);
  }

  #search-input::placeholder {
    color: var(--linear-muted);
  }

  .filter-group {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .filter-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--linear-muted);
    padding-top: 0.25rem;
    white-space: nowrap;
    min-width: 5rem;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .chip {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--linear-border-subtle);
    background: transparent;
    color: var(--linear-subtext);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .chip:hover {
    background: var(--linear-overlay-soft);
    color: var(--linear-text);
  }

  .chip.active {
    background: var(--linear-accent-green);
    border-color: var(--linear-accent-green);
    color: #fff;
  }

  .chip--category {
    font-size: 0.68rem;
    padding: 0.15rem 0.55rem;
    background: rgba(45, 122, 103, 0.1);
    border-color: rgba(45, 122, 103, 0.25);
    color: var(--linear-accent-green);
    pointer-events: none;
  }

  /* ── Result count ── */
  .result-count {
    font-size: 0.8rem;
    color: var(--linear-muted);
    margin-bottom: 1rem;
    max-width: 760px;
  }

  /* ── Posts list ── */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 760px;
  }

  .post-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--linear-text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--linear-muted);
    font-weight: 500;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: var(--linear-overlay-soft);
    border: 1px solid var(--linear-border-subtle);
    color: var(--linear-subtext);
  }

  .post-row h2 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--linear-text-bright);
    line-height: 1.35;
  }

  .post-summary {
    font-size: 0.875rem;
    color: var(--linear-subtext);
    line-height: 1.6;
  }

  .post-read-more {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--linear-accent-green);
    margin-top: 0.25rem;
  }

  .empty-state {
    color: var(--linear-muted);
    padding: 4rem 0;
    text-align: center;
    max-width: 760px;
  }
</style>
